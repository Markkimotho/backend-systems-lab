REDIS_HOST=127.0.0.1
REDIS_PORT=6380
REQUIREPASS=                  # set a password to enable AUTH
MAX_KEYS=0                    # max keys stored (0 = unlimited, LRU eviction when set)
RATE_LIMITER_PORT=8080
LOAD_BALANCER_PORT=8090
LOAD_BALANCER_HOST=127.0.0.1
SERVER_1_HOST=127.0.0.1
SERVER_2_HOST=127.0.0.1
SERVER_3_HOST=127.0.0.1
SERVER_1_PORT=8001
SERVER_2_PORT=8002
SERVER_3_PORT=8003
HEALTH_CHECK_INTERVAL=5
FORWARD_TIMEOUT=30            # seconds before proxied request is timed out
CONNECT_TIMEOUT=5             # seconds before TCP connect to backend is timed out
